<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_sheet_surface"
    android:clipToPadding="false"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/layout_checkout_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:minHeight="60dp"
        android:orientation="horizontal"
        android:paddingLeft="16dp"
        android:paddingTop="12dp"
        android:paddingRight="16dp"
        android:paddingBottom="12dp">

        <ImageButton
            android:id="@+id/button_back"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:contentDescription="Quay lai"
            android:padding="6dp"
            android:src="@drawable/ic_arrow_back_small"
            android:tint="@color/coffee_500" />

        <TextView
            android:id="@+id/text_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:text="Thanh to&#225;n"
            android:textColor="@color/coffee_950"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/button_close"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:contentDescription="Dong"
            android:padding="6dp"
            android:src="@drawable/ic_close_small"
            android:tint="@color/coffee_400" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/coffee_200" />

    <LinearLayout
        android:id="@+id/layout_checkout_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="16dp"
        android:paddingTop="14dp"
        android:paddingRight="16dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:id="@+id/card_total_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_surface_card"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingLeft="16dp"
            android:paddingTop="14dp"
            android:paddingRight="16dp"
            android:paddingBottom="14dp">

            <TextView
                android:id="@+id/text_total_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="T&#7893;ng thanh to&#225;n"
                android:textColor="@color/coffee_500"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/text_total_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/coffee_700"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_item_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/coffee_500"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/text_payment_section_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Ch&#7885;n ph&#432;&#417;ng th&#7913;c thanh to&#225;n"
            android:textColor="@color/coffee_950"
            android:textSize="15sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/layout_payment_methods"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_payment_cash"
                android:layout_width="0dp"
                android:layout_height="108dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/coffee_200"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <FrameLayout
                        android:id="@+id/layout_cash_icon_bg"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_payment_icon_idle">

                        <ImageView
                            android:id="@+id/image_cash_icon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:contentDescription="Tien mat"
                            android:src="@drawable/ic_payment_cash"
                            android:tint="@color/coffee_700" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/text_cash_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Ti&#7873;n m&#7863;t"
                        android:textColor="@color/coffee_950"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_payment_qr"
                android:layout_width="0dp"
                android:layout_height="108dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/coffee_200"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <FrameLayout
                        android:id="@+id/layout_qr_icon_bg"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_payment_icon_idle">

                        <ImageView
                            android:id="@+id/image_qr_icon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:contentDescription="Chuyen khoan QR"
                            android:src="@drawable/ic_payment_qr"
                            android:tint="@color/coffee_700" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/text_qr_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Chuy&#7875;n kho&#7843;n QR"
                        android:textColor="@color/coffee_950"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_cash_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_surface_card"
            android:orientation="vertical"
            android:paddingLeft="14dp"
            android:paddingTop="14dp"
            android:paddingRight="14dp"
            android:paddingBottom="14dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/text_cash_section_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chi ti&#7871;t ti&#7873;n m&#7863;t"
                android:textColor="@color/coffee_950"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_cash_label_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Kh&#225;ch &#273;&#432;a (&#273;)"
                android:textColor="@color/coffee_700"
                android:textSize="13sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/layout_cash_input_box"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_payment_input_box"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingLeft="14dp"
                android:paddingRight="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edit_cash_received"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:gravity="start"
                    android:hint="0"
                    android:inputType="number"
                    android:maxLines="1"
                    android:textColor="@color/coffee_950"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="22dp"
                    android:layout_height="28dp"
                    android:layout_marginStart="6dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageButton
                        android:id="@+id/button_cash_up"
                        android:layout_width="22dp"
                        android:layout_height="11dp"
                        android:background="@android:color/transparent"
                        android:contentDescription="Tang tien khach dua"
                        android:padding="0dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_chevron_up"
                        android:tint="@color/coffee_400" />

                    <ImageButton
                        android:id="@+id/button_cash_down"
                        android:layout_width="22dp"
                        android:layout_height="11dp"
                        android:layout_marginTop="4dp"
                        android:background="@android:color/transparent"
                        android:contentDescription="Giam tien khach dua"
                        android:padding="0dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_chevron_down"
                        android:tint="@color/coffee_400" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_cash_result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_payment_status_success"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingLeft="12dp"
                android:paddingTop="12dp"
                android:paddingRight="12dp"
                android:paddingBottom="12dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/text_cash_result_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/success"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/text_cash_result_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/success"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_qr_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_surface_card"
            android:orientation="vertical"
            android:paddingLeft="14dp"
            android:paddingTop="14dp"
            android:paddingRight="14dp"
            android:paddingBottom="14dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/text_qr_section_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Th&#244;ng tin chuy&#7875;n kho&#7843;n"
                android:textColor="@color/coffee_950"
                android:textSize="15sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/image_qr_code"
                android:layout_width="104dp"
                android:layout_height="104dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:contentDescription="QR thanh toan"
                android:padding="18dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_payment_qr" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Ng&#226;n h&#224;ng"
                    android:textColor="@color/coffee_500"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/text_bank_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/coffee_950"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="6dp"
                android:background="@color/coffee_200" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="S&#7889; t&#224;i kho&#7843;n"
                    android:textColor="@color/coffee_500"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/text_account_number"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/coffee_950"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="6dp"
                android:background="@color/coffee_200" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Ch&#7911; t&#224;i kho&#7843;n"
                    android:textColor="@color/coffee_500"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/text_account_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/coffee_950"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="6dp"
                android:background="@color/coffee_200" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="S&#7889; ti&#7873;n"
                    android:textColor="@color/coffee_500"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/text_qr_amount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/coffee_700"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="6dp"
                android:background="@color/coffee_200" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="N&#7897;i dung"
                    android:textColor="@color/coffee_500"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/text_transfer_content"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/coffee_950"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/coffee_200" />

    <LinearLayout
        android:id="@+id/layout_button_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingLeft="16dp"
        android:paddingTop="10dp"
        android:paddingRight="16dp"
        android:paddingBottom="10dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_confirm_payment"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_payment_button_disabled"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="X&#225;c nh&#7853;n thanh to&#225;n"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="@null" />
    </LinearLayout>

</LinearLayout>
