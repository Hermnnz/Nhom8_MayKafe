<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_sheet_surface"
        android:clipToPadding="false"
        android:orientation="vertical">

        <include layout="@layout/include_bottom_sheet_header" />

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fillViewport="true"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingLeft="16dp"
                android:paddingTop="12dp"
                android:paddingRight="16dp"
                android:paddingBottom="20dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/layout_image_preview"
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    app:cardBackgroundColor="@color/coffee_100"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@android:color/transparent"
                    app:strokeWidth="0dp">

                    <ImageView
                        android:id="@+id/image_preview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@color/coffee_100"
                        android:contentDescription="Xem tr&#432;&#7899;c &#7843;nh"
                        android:scaleType="centerCrop" />

                    <TextView
                        android:id="@+id/button_preview_image"
                        android:layout_width="wrap_content"
                        android:layout_height="30dp"
                        android:layout_gravity="bottom|start"
                        android:layout_marginLeft="12dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/bg_menu_preview_badge"
                        android:gravity="center"
                        android:paddingLeft="10dp"
                        android:paddingRight="10dp"
                        android:text="Xem tr&#432;&#7899;c &#7843;nh"
                        android:textColor="@color/white"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="T&#234;n m&#243;n"
                    android:textColor="@color/coffee_950"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/input_name"
                    style="@style/Widget.MayKafe.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:boxBackgroundColor="@color/white"
                    app:boxStrokeColor="@color/coffee_200">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edit_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Nh&#7853;p t&#234;n m&#243;n"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp"
                        android:textColor="@color/coffee_950"
                        android:textColorHint="@color/coffee_300"
                        android:textSize="15sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Gi&#225; (VN&#272;)"
                    android:textColor="@color/coffee_950"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/input_price"
                    style="@style/Widget.MayKafe.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:boxBackgroundColor="@color/white"
                    app:boxStrokeColor="@color/coffee_200">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edit_price"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Nh&#7853;p gi&#225;"
                        android:inputType="number"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp"
                        android:textColor="@color/coffee_950"
                        android:textColorHint="@color/coffee_300"
                        android:textSize="15sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Danh m&#7909;c"
                    android:textColor="@color/coffee_950"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/input_category"
                    style="@style/Widget.MayKafe.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:boxBackgroundColor="@color/white"
                    app:boxStrokeColor="@color/coffee_200"
                    app:endIconMode="dropdown_menu">

                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                        android:id="@+id/edit_category"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:completionThreshold="0"
                        android:inputType="none"
                        android:dropDownVerticalOffset="8dp"
                        android:popupBackground="@drawable/bg_menu_dropdown_popup"
                        android:popupElevation="12dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp"
                        android:textColor="@color/coffee_950"
                        android:textSize="15sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="URL h&#236;nh &#7843;nh (t&#249;y ch&#7885;n)"
                    android:textColor="@color/coffee_950"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/input_image_url"
                    style="@style/Widget.MayKafe.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:boxBackgroundColor="@color/white"
                    app:boxStrokeColor="@color/coffee_200"
                    app:endIconDrawable="@drawable/ic_attach_file"
                    app:endIconMode="custom"
                    app:endIconTint="@color/coffee_700">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edit_image_url"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="https://... (&#273;&#7875; tr&#7889;ng d&#249;ng &#7843;nh m&#7863;c &#273;&#7883;nh)"
                        android:inputType="textUri"
                        android:maxLines="1"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp"
                        android:textColor="@color/coffee_950"
                        android:textColorHint="@color/coffee_300"
                        android:textSize="15sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:id="@+id/text_selected_image_file"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_menu_action_neutral"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:paddingLeft="14dp"
                    android:paddingTop="10dp"
                    android:paddingRight="14dp"
                    android:paddingBottom="10dp"
                    android:textColor="@color/coffee_700"
                    android:textSize="13sp"
                    android:visibility="gone" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_submit_menu"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/bg_primary_button"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="Th&#234;m m&#243;n"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:backgroundTint="@null" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>
</FrameLayout>
