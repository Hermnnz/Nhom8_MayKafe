<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/coffee_50"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/text_detail_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/coffee_950"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/text_detail_meta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/coffee_500"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/text_detail_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:paddingLeft="10dp"
        android:paddingTop="4dp"
        android:paddingRight="10dp"
        android:paddingBottom="4dp"
        android:textSize="12sp"
        android:textStyle="bold" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_detail_items"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:nestedScrollingEnabled="false" />

    <TextView
        android:id="@+id/text_detail_payment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:textColor="@color/coffee_500"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/text_detail_note"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/danger"
        android:textSize="13sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/text_detail_total"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="end"
        android:textColor="@color/coffee_700"
        android:textSize="18sp"
        android:textStyle="bold" />
</LinearLayout>
