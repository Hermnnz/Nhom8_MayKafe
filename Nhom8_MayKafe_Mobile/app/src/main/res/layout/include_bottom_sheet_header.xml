<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android">

    <LinearLayout
        android:id="@+id/layout_sheet_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:baselineAligned="false"
        android:gravity="center_vertical"
        android:minHeight="60dp"
        android:orientation="horizontal"
        android:paddingLeft="16dp"
        android:paddingTop="12dp"
        android:paddingRight="16dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/text_sheet_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/coffee_950"
                android:textSize="19sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_sheet_meta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/coffee_500"
                android:textSize="14sp"
                android:visibility="gone" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/button_close_sheet"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:contentDescription="&#272;&#243;ng"
            android:padding="6dp"
            android:src="@drawable/ic_close_small"
            android:tint="@color/coffee_400" />
    </LinearLayout>

    <View
        android:id="@+id/divider_sheet_header"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/coffee_200" />

</merge>
