<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_print_feedback"
    android:gravity="center_vertical"
    android:minHeight="60dp"
    android:orientation="horizontal"
    android:paddingLeft="16dp"
    android:paddingTop="12dp"
    android:paddingRight="16dp"
    android:paddingBottom="12dp">

    <FrameLayout
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:background="@drawable/bg_print_feedback_icon">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_gravity="center"
            android:contentDescription="Thành công"
            android:src="@drawable/ic_check_small"
            android:tint="@color/white" />
    </FrameLayout>

    <TextView
        android:id="@+id/text_feedback_message"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:maxLines="1"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:textStyle="bold" />

    <ImageView
        android:id="@+id/button_feedback_close"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:contentDescription="Đóng"
        android:src="@drawable/ic_close_small"
        android:tint="@color/coffee_200" />
</LinearLayout>
